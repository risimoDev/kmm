        "jsCode": "const input = $input.first().json;\nconst body = input.body || input;\n\nconst sessionId = body.session_id;\nif (!sessionId) throw new Error('session_id is required');\n\nconst validChannels = ['youtube', 'tiktok', 'instagram', 'vk', 'telegram'];\nconst channels = (body.channels || ['telegram']).filter(ch => validChannels.includes(ch));\nif (channels.length === 0) throw new Error('No valid channels provided');\n\nreturn [{ json: {\n  session_id: sessionId,\n  channels: channels,\n  caption_override: body.caption_override || ''\n}}];"
      },

    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst ch = data.publish_channel || data.channel || 'unknown';\nconst resp = data;\n\nlet success = false;\nlet externalId = '';\nlet externalUrl = '';\n\nif (ch === 'telegram') {\n  success = !!resp.ok || !!resp.result;\n  externalId = String(resp.result?.message_id || '');\n} else if (ch === 'vk') {\n  success = !!resp.response;\n  externalId = String(resp.response?.video_id || '');\n  externalUrl = resp.response?.video_url || '';\n} else if (ch === 'youtube') {\n  success = !!resp.id || (resp.statusCode >= 200 && resp.statusCode < 300);\n  externalId = resp.id || '';\n  externalUrl = resp.id ? 'https://youtube.com/shorts/' + resp.id : '';\n} else if (ch === 'tiktok') {\n  success = resp.error?.code === 'ok' || resp.data?.publish_id;\n  externalId = resp.data?.publish_id || '';\n} else if (ch === 'instagram') {\n  success = !!resp.id;\n  externalId = resp.id || '';\n}\n\nconst sessionId = data.session_id || $('🔧 Подготовка данных').first().json.session_id;\n\nreturn [{ json: {\n  session_id: sessionId,\n  channel: ch,\n  success: success,\n  external_id: externalId,\n  external_url: externalUrl,\n  caption: data.generated_caption || ''\n}}];"
      },
